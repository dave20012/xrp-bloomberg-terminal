# Redis connection (required for production deployments)
REDIS_URL=redis://localhost:6379

# Optional: Binance API keys for signed netflows
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Optional: News sentiment worker configuration
NEWS_API_KEY=
HF_TOKEN=
SENTIMENT_RUN_INTERVAL=1800

# Optional: XRPL inflow worker configuration
XRPL_INFLOWS_PROVIDER=ripple_data
XRPL_MIN_XRP=10000000
XRPL_LOOKBACK_SECONDS=
WHALE_ALERT_KEY=
XRPL_POLL_SECONDS=30
XRPL_INSPECT_ACCOUNT=

# Streamlit dashboard tuning
META_REFRESH_SECONDS=45
SENTIMENT_EMA_ALPHA=0.3
RATIO_EMA_ALPHA=0.1

# PostgreSQL / TimescaleDB connection settings
# The ingestion worker and backtesting scripts use these values.  When
# deploying on Railway with the Postgres plugin you can leave these
# blank; Railway will set them automatically.
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DB=
